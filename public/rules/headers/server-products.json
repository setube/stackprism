            "patterns": ["fastly"]
          },
          {
            "name": "Bunny CDN",
            "patterns": ["bunnycdn|bunny"]
          },
          {
            "name": "Gcore CDN",
            "patterns": ["gcore"]
          },
          {
            "name": "Tencent Cloud CDN",
