          {
            "name": "OpenSwoole",
            "patterns": ["openswoole|open\\s*swoole"]
          },
          {
            "name": "WEBrick",
            "patterns": ["\\bwebrick\\b"]
          },
          {
            "name": "Python http.server",
            "patterns": ["basehttp|python.*http\\.server"]
          },
          {
            "name": "GoAhead WebServer",
            "patterns": ["goahead[-\\s]?webs?"]
          },
          {
            "name": "lighttpd",
            "patterns": ["\\blighttpd\\b"]
          },
          {
            "name": "Payara Server",
            "patterns": ["\\bpayara\\b"]
