        },
        "rules": [
          {
            "name": "Vercel",
            "patterns": ["vercel"]
          },
          {
            "name": "Cloudflare",
            "patterns": ["cloudflare"]
          },
          {
            "name": "AmazonS3",
            "patterns": ["amazons3|amazon s3|s3"]
          },
          {
            "name": "Akamai",
