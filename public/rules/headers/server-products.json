            "name": "Rust Poem",
            "patterns": ["\\bpoem\\b"]
          },
          {
            "name": "Rust Salvo",
            "patterns": ["\\bsalvo\\b"]
          },
          {
            "name": "Rust Tide",
            "patterns": ["\\btide\\b"]
          },
          {
            "name": "Rust Ntex",
            "patterns": ["\\bntex\\b"]
          },
          {
            "name": "Rust Hyper",
            "confidence": "中",
            "patterns": ["\\bhyper\\b"]
          },
          {
            "name": "Quarkus",
            "patterns": ["\\bquarkus\\b"]
          },
          {
            "name": "Micronaut",
            "patterns": ["\\bmicronaut\\b"]
          },
          {
